# Smart Safety LLM Wiki Access Control
WIKI_ACCESS_KEY="2026strange"

# Quantitative RAG Debug Options
RAG_DEBUG=false
DEBUG_RAG_BENCHMARK=false

# LLM Answer Mode Decoupling
ENABLE_LLM_ANSWER=false # Set to true to call external LLM providers
LLM_PROVIDER=none # none, mock, gemini, cloudflare, openai
LLM_MODEL= # Leave blank to use provider defaults (e.g. gemini-1.5-flash)
LLM_TIMEOUT_MS=10000 # Timeout threshold in milliseconds
LLM_MAX_CONTEXT_CHUNKS=8 # Maximum retrieved passages sent to LLM context
LLM_MAX_OUTPUT_TOKENS=800

# Google Gemini Credentials
GEMINI_API_KEY=

# Cloudflare Workers AI Credentials
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# OpenAI API Credentials
OPENAI_API_KEY=
