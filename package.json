{
  "name": "smart-safety-llm-wiki",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run generate:index && npm run rag:index && vite --host 0.0.0.0",
    "generate:index": "node scripts/generate-search-index.mjs && node scripts/generate-wiki-ux-meta.mjs",
    "generate:ux-meta": "node scripts/generate-wiki-ux-meta.mjs",
    "rag:index": "node scripts/generate-rag-index.mjs",
    "export:obsidian": "node scripts/export-to-obsidian.mjs",
    "check:index": "node scripts/check-index-freshness.mjs",
    "rag:eval": "node scripts/rag-eval.mjs",
    "rag:report": "node scripts/rag-report.mjs",
    "rag:leaderboard": "node scripts/rag-leaderboard.mjs",
    "rag:chunk-experiment": "node scripts/rag-chunk-experiment.mjs",
    "rag:hybrid-stage3": "node scripts/rag-hybrid-stage3.mjs",
    "rag:abstention-eval": "node scripts/rag-abstention-eval.mjs",
    "rag:camera-registry-eval": "node scripts/rag-camera-registry-eval.mjs",
    "test": "node --test tests/*.test.mjs",
    "start": "node server.mjs",
    "preview": "npm run build && node server.mjs",
    "preview:dist": "node server.mjs",
    "build": "npm run generate:index && npm run rag:index && npm run check:index && tsc -b && vite build",
    "benchmark:rag": "node scripts/run-benchmark.mjs",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "4.7.0",
    "mermaid": "^11.16.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "typescript": "^5.9.3",
    "vite": "6.3.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.26",
    "@types/react-dom": "^18.3.7",
    "react-doctor": "0.7.8",
    "react-grab": "0.1.48",
    "react-scan": "0.5.7"
  }
}
